{
  "description": "Hakim Claude Code lifecycle integration: automatic session activation plus optional post-edit diagnostics.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/session_start.mjs"
            ],
            "timeout": 5,
            "statusMessage": "Activating Hakim"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/post_tool_use_diagnostic.mjs"
            ],
            "timeout": 5,
            "statusMessage": "Hakim diagnostic check"
          }
        ]
      }
    ]
  }
}
